<<<TAR_UNCOMPRESS>>>
	CFLAGS="${CFLAGS} -fPIC"
	./configure --prefix=<<<CROSS_TOOLS_PREFIX>>> --with-platlibdir=lib${LIB_SUFF} \
	            --disable-shared --with-system-expat --with-system-ffi \
	            --with-ensurepip=yes --enable-optimizations \
	            ac_cv_broken_sem_getvalue=yes
#  LIBSQLITE3_LIBS="-L${CROSSTOOLS_DIR}/lib64 -Wl,-rpath=${CROSSTOOLS_DIR}/lib64 -lsqlite3"
	<<<MAKE_AND_INSTALL>>>

#	echo "${PACKAGE_VERSION%\.*}" > ${COMMON_DIR}/Python3.version
	save_package_version Python3 "${PACKAGE_VERSION%\.*}"
	PYTHON_VERSION="<<<PYTHON_VERSION>>>"

	sed -i "s@-lutil @@g" <<<CROSS_TOOLS_PREFIX>>>/bin/python<<<PYTHON_VERSION>>>-config

