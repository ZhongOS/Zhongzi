	rm -fv man/man8/arpd.8
	PKG_CONFIG=${CROSS_TARGET}-pkg-config \
	<<<MAKE>>> CC="${CROSS_TARGET}-gcc" HOSTCC="gcc" KERNEL_INCLUDE=${SYSROOT_DIR}/usr/include \
