<<<TAR_UNCOMPRESS>>>
	<<<MAKE>>> CC="${CROSS_TARGET}-gcc" CXFLAGS="${CFLAGS} -Wno-error=unterminated-string-initialization -Wno-error=format-truncation -Wno-error=format -Wno-error=unused-but-set-variable -Wno-error=format-overflow"
# mdadm软件包使用CXFLAGS来传递CFLAGS参数，以保证其内部参数传递正确。
	make DESTDIR=${SYSROOT_DIR} PKG_CONFIG=${CROSS_TARGET}-pkg-config install
<<<CLEAR_DIR>>>
