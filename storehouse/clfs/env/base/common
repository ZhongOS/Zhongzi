export PREFIX=/usr
export LDFLAGS="-Wl,-rpath-link=${SYSROOT_DIR}/usr/lib${LIB_SUFF}"
export PKG_CONFIG_SYSROOT_DIR=${SYSROOT_DIR}
export PKG_CONFIG_PATH="${SYSROOT_DIR}/usr/lib${LIB_SUFF}/pkgconfig:${SYSROOT_DIR}/usr/share/pkgconfig"
export PKG_CONFIG_LIBDIR="${SYSROOT_DIR}/usr/lib${LIB_SUFF}/pkgconfig:${SYSROOT_DIR}/usr/share/pkgconfig"
export COMMON_CONFIG="--prefix=/usr --sysconfdir=/etc --localstatedir=/var --libdir=/usr/lib${LIB_SUFF} \
                      --build=${CROSS_HOST} --host=${CROSS_TARGET}"
export MAKE_AND_INSTALL="make -j${JOBS} && run_step_package_check && make DESTDIR=${SYSROOT_DIR} install && rm -f ${SYSROOT_DIR}/usr/lib${LIB_SUFF}/*.la"
export MESON_CONFIG="--prefix=/usr --libdir=/usr/lib${LIB_SUFF} --sysconfdir=/etc --localstatedir=/var --libexecdir=/usr/libexec --buildtype=release \
			--cross-file ${COMMON_DIR}/meson-cross.txt"
export NINJA_AND_INSTALL="CC=${CROSS_TARGET}-gcc ninja && run_step_package_check ninja && DESTDIR=${SYSROOT_DIR} ninja install"
export CFLAGS="-g ${CFLAGS} -Wno-incompatible-pointer-types -Wno-implicit-int -Wno-implicit-function-declaration"
