<<<TAR_UNCOMPRESS>>>
    sed -i -e "/dep_scanner =/s@, native: true@@g" \
           -e "/prog_scanner =/s@find_program\(.*\)\$@find_program('wayland-scanner')@g" \
           protocol/meson.build
