CONFIG_ENV=_PYTHON_HOST_PLATFORM=linux-loongarch64 _PYTHON_SYSCONFIGDATA_NAME=_sysconfigdata__linux_${CROSS_TARGET} CXXFLAGS="${CXXFLAGS} -I${SYSROOT_DIR}/usr/include/PySide6/KCoreAddons"
EXTRA_PARM=-DPython_EXECUTABLE=${HOST_TOOLS_DIR}/bin/python3 -DPython3_EXECUTABLE=${HOST_TOOLS_DIR}/bin/python3
