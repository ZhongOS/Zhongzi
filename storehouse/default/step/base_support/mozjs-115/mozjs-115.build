<<<TAR_UNCOMPRESS>>>
    PATH=${HOST_TOOLS_DIR}/python3_13/bin:${PATH}
    <<<PATCH>>>
#    cp -v ${SYSROOT_DIR}/usr/share/automake-*/config.* build/autoconf/
#    cp -a ${CROSSTOOLS_DIR}/lib/python<<<PYTHON_VERSION>>>/site-packages/setuptools{,-*} third_party/python/setuptools/
#    cp -a ${CROSSTOOLS_DIR}/lib/python<<<PYTHON_VERSION>>>/site-packages/six{.py,-*} third_party/python/six/
#    cp -a ${SYSROOT_DIR}/lib/python<<<PYTHON_VERSION>>>/site-packages/six{.py,-*} third_party/python/six/
# 当rust target没有默认设置sysroot时，配置出现错误，强制去掉对target使用--sysroot ${SYSROOT_DIR}的情况下的探测过程以保证配置通过。
    sed -i "/assert_rust_compile(target/d" build/moz.configure/rust.configure
    mkdir cross-build
    pushd cross-build
#	chmod +x ../js/src/configure.in
	export RUSTFLAGS="$RUSTFLAGS -Ccode-model=medium --sysroot=${CROSSTOOLS_DIR}"
        CC="${CROSS_TARGET}-gcc" CXX="${CROSS_TARGET}-g++" \
	LDFLAGS="${LDFLAGS} -Wl,--copy-dt-needed-entries" \
        ../js/src/configure --prefix=/usr --libdir=/usr/lib64 \
                    --target=${CROSS_TARGET} \
                    --with-intl-api --with-system-zlib --with-system-icu \
                    --disable-jemalloc --disable-debug-symbols --enable-readline
#	cp -a ${CROSSTOOLS_DIR}/lib/python<<<PYTHON_VERSION>>>/site-packages/distutils-precedence.pth _virtualenvs/build/lib/python<<<PYTHON_VERSION>>>/site-packages/
	<<<MAKE_AND_INSTALL>>>
        rm -v ${SYSROOT_DIR}/usr/lib64/libjs_static.ajs
        sed -i '/@NSPR_CFLAGS@/d' ${SYSROOT_DIR}/usr/bin/js115-config
    popd
<<<CLEAR_DIR>>>


[[[115.34.0]]]
<<<TAR_UNCOMPRESS>>>
    PATH=${HOST_TOOLS_DIR}/python3_13/bin:${PATH}
    <<<PATCH>>>
