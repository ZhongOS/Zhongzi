        rm -f ${SYSROOT_DIR}/usr/lib64/*.la

	make distclean

	PATH=${CROSSTOOLS_DIR}/ocaml-cross/bin:${PATH}
	./configure --host=${CROSS_TARGET} --prefix=/usr --libdir=/usr/lib64/ocaml --sysconfdir=/etc --datadir=/usr/share
