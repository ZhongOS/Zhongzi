[[[4.999.0]]]
<<<TAR_UNCOMPRESS>>>
        <<<PATCH>>>
        for config_i in $(find -name "config.sub")
        do
                cp -a -f <<<CROSS_TOOLS_PREFIX>>>/share/automake*/config.* $(dirname ${config_i})/
        done
        if [ ! -f configure ]; then
                autoreconf -ifv
        fi
        # CFLAGS="-Wno-error=incompatible-pointer-types -Wno-error=strict-prototypes" 
	./configure --prefix=/usr --sysconfdir=/etc --localstatedir=/var --libdir=/usr/lib${LIB_SUFF}/ocaml --datarootdir=/usr/share \
                    --build=${CROSS_HOST} --host=${CROSS_TARGET} --enable-malloc0returnsnull
        <<<MAKE>>> 
        make DESTDIR=${SYSROOT_DIR} install
        rm -f ${SYSROOT_DIR}/usr/lib64/*.la
        make DESTDIR=${PWD}/ocaml-$(echo "<<<PACKAGE_VERSION>>>" | sed "s@-default@@g")-${ARCH_NAME} install
	mkdir -pv ${DIST_DIRECTORY}/host/${ARCH_NAME}/ocaml/$(echo "<<<PACKAGE_VERSION>>>" | sed "s@-default@@g")/
	tar -cJf ${DIST_DIRECTORY}/host/${ARCH_NAME}/ocaml/$(echo "<<<PACKAGE_VERSION>>>" | sed "s@-default@@g")/ocaml-$(echo "<<<PACKAGE_VERSION>>>" | sed "s@-default@@g")-${ARCH_NAME}.tar.xz ocaml-$(echo "<<<PACKAGE_VERSION>>>" | sed "s@-default@@g")-${ARCH_NAME}
<<<CLEAR_DIR>>>

