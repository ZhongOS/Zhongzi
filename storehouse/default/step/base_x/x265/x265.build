<<<TAR_UNCOMPRESS>>>
    mkdir cross-build
    pushd cross-build
        CC="${CROSS_TARGET}-gcc" CXX="${CROSS_TARGET}-g++" \
        cmake -G "Unix Makefiles" -DCMAKE_BUILD_TYPE=Release \
              -DCMAKE_INSTALL_PREFIX=/usr -DLIB_INSTALL_DIR=/usr/lib64 \
              -DGIT_ARCHETYPE=1 ../source
	<<<MAKE_AND_INSTALL>>>
    popd
<<<CLEAR_DIR>>>
