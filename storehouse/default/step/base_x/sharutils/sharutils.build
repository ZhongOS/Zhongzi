<<<TAR_UNCOMPRESS>>>
    sed -i 's/BUFSIZ/rw_base_size/' src/unshar.c
    sed -i '/program_name/s/^/extern /' src/*opts.h
    sed -i 's/IO_ftrylockfile/IO_EOF_SEEN/' lib/*.c
    echo "#define _IO_IN_BACKUP 0x100" >> lib/stdio-impl.h
    ./configure ${COMMON_CONFIG}
    <<<MAKE_AND_INSTALL>>>
<<<CLEAR_DIR>>>
