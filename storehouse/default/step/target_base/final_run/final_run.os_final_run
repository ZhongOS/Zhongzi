sed -i -e "s@${SYSROOT_DIR}@@g" \
       -e "s@${CROSSTOOLS_DIR}/bin/${CROSS_TARGET}-@/usr/bin/@g" \
       $(file <OVERLAY_SYSROOT_DIR>/usr/lib${LIB_SUFF}/rustlib/* | grep ASCII | awk -F':' '{ print $1 }') \
       ${TEMP_DIRECTORY}/strip-foo


sed -i -e "s@${CROSSTOOLS_DIR}/qt6/bin@/usr/bin@g" \
       $(find <OVERLAY_SYSROOT_DIR>/usr/lib/ -type f -name "*.service") \
       ${TEMP_DIRECTORY}/strip-foo

if [ -d <OVERLAY_SYSROOT_DIR>/usr/lib${LIB_SUFF}/ ]; then
        find <OVERLAY_SYSROOT_DIR>/usr/lib${LIB_SUFF}/ -type f -name "*.la" -exec rm '{}' ';'
        find <OVERLAY_SYSROOT_DIR>/usr/lib${LIB_SUFF}/ -type f -name "*.prl" -exec rm '{}' ';'
fi

