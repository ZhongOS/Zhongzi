rm -f <OVERLAY_SYSROOT_DIR>/usr/lib${LIB_SUFF}/perl5/5.4x/site_perl/auto/XML/Parser/.packlist
rm -f <OVERLAY_SYSROOT_DIR>/usr/lib${LIB_SUFF}/perl5/5.4x/site_perl/auto/URI/.packlist
rm -f <OVERLAY_SYSROOT_DIR>/usr/lib/rustlib/install.log

# sed -i -e "s@${CROSSTOOLS_DIR}/bin/${CROSS_TARGET}-@/usr/bin/@g" \

touch ${TEMP_DIRECTORY}/strip-foo

