<<<TAR_UNCOMPRESS>>>
        <<<PATCH>>>
        for config_i in $(find -name "config.sub")
        do
                cp -a -f $(automake --print-libdir)/config.{sub,guess} $(dirname ${config_i})/
        done
        if [ ! -f configure ]; then
                autoreconf -ifv
        fi

	./configure --prefix=${PREFIX} \
		--with-pc_path=${PREFIX}/lib64/pkgconfig:${PREFIX}/lib/pkgconfig --with-internal-glib --disable-host-tool

        <<<MAKE_AND_INSTALL>>>
<<<CLEAR_DIR>>>
