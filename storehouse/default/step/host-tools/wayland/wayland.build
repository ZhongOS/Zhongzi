<<<TAR_UNCOMPRESS>>>
    <<<PATCH>>>
    mkdir -p native-build
    pushd native-build
        meson --prefix=${PREFIX} --libdir=${PREFIX}/lib${LIB_SUFF} -Ddocumentation=false \
              --buildtype=release ..
        ninja
        ninja install
    popd
