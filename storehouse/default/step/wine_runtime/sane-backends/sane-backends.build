<<<TAR_UNCOMPRESS>>>
        <<<PATCH>>>
	echo ${PACKAGE_VERSION} > .tarball-version
        if [ ! -f configure ]; then
                autoreconf -ifv
        fi
        <<<CONFIG_ENV>>> ./configure ${COMMON_CONFIG} --enable-static <<<EXTRA_PARM>>> --enable-malloc0returnsnull
        CC="${X86_HOST}-gcc" CXX="${X86_HOST}-g++" <<<MAKE>>>
        make DESTDIR=${X86_SYSROOT_DIR} install
        rm -f ${X86_SYSROOT_DIR}/usr/lib${LIB_SUFF}/*.la
<<<CLEAR_DIR>>>


