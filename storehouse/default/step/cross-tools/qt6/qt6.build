<<<TAR_UNCOMPRESS>>>
	<<<PATCH>>>

#	sed -i "/embree/d" qtquick3d/src/3rdparty/CMakeLists.txt
#	sed -i "/QT_QUICK3D_HAS_EMBREE/d" qtquick3d/src/3rdparty/CMakeLists.txt

	mkdir -p native-build
	pushd native-build
		LDFLAGS="${LDFLAGS} -Wl,-rpath=${CROSSTOOLS_DIR}/lib64" \
		cmake -DCMAKE_INSTALL_PREFIX=${CROSSTOOLS_DIR}/qt6 \
		      -DCMAKE_BUILD_TYPE=RELEASE \
		      -DICU_ROOT=${HOST_TOOLS_DIR} \
		      -DQT_FEATURE_system_freetype=OFF \
		      -DQT_BUILD_EXAMPLES_AS_EXTERNAL=ON \
		      -DQT_BUILD_SUBMODULES=qtbase\;qtshadertools\;qtdeclarative\;qt3d\;qtquick3d\;qttools\;qtremoteobjects\;qtscxml\;qtwayland\;qtmultimedia\;qt5compat\;qtopcua\;qtlottie \
		      ..
		<<<MAKE_AND_INSTALL>>>
	popd
	mkdir -p ${CROSSTOOLS_DIR}/qt6/lib64/qt6/
	ln -sf ${CROSSTOOLS_DIR}/qt6/libexec ${CROSSTOOLS_DIR}/qt6/lib64/qt6/
	pushd qtwebengine/src/gn
		mkdir -p build
		pushd build
			cmake -DCMAKE_INSTALL_PREFIX=${CROSSTOOLS_DIR}/qt6 \
	                      -DCMAKE_BUILD_TYPE=RELEASE \
        	              ..
			<<<MAKE_AND_INSTALL>>>
		popd
	popd
