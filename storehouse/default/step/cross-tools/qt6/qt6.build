# 		pushd build
# 			cmake -DCMAKE_INSTALL_PREFIX=${CROSSTOOLS_DIR}/qt6 \
# 	                      -DCMAKE_BUILD_TYPE=RELEASE \
#         	              ..
# 			<<<MAKE_AND_INSTALL>>>
# 		popd
# 	popd
<<<CLEAR_DIR>>>


