<<<TAR_UNCOMPRESS>>>
	<<<PATCH>>>
	mkdir cross-build
	pushd cross-build
		meson ${MESON_CONFIG} \
			..
		sed -i "s@gi-docgen \(index\|generate\|gen-index\|gen-deps\|search\|check\|serve\) @& --add-include-path ${SYSROOT_DIR}/usr/share/gir-1.0/ @g" build.ninja
		<<<NINJA_AND_INSTALL>>>
	popd
	rm -f ${SYSROOT_DIR}/usr/lib${LIB_SUFF}/*.la
	cp ${SYSROOT_DIR}/usr/lib${LIB_SUFF}/pkgconfig/{${STEP_PACKAGENAME}-${PACKAGE_VERSION%\.*},${STEP_PACKAGENAME}}.pc
<<<CLEAR_DIR>>>
