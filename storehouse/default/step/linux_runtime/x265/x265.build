<<<TAR_UNCOMPRESS>>>
    <<<PATCH>>>
    mkdir cross-build
    pushd cross-build
        CC="${LINUX_HOST}-gcc" CXX="${LINUX_HOST}-g++" \
        cmake -G "Unix Makefiles" -DCMAKE_BUILD_TYPE=Release \
              -DCMAKE_INSTALL_PREFIX=/usr -DLIB_INSTALL_DIR=/usr/lib${LIB_SUFF} -DENABLE_ASSEMBLY=OFF \
	      -DCMAKE_POLICY_VERSION_MINIMUM=3.5 \
              -DGIT_ARCHETYPE=1 \
	      -Wno-dev ../source
	<<<MAKE_AND_INSTALL>>>
    popd
<<<CLEAR_DIR>>>
