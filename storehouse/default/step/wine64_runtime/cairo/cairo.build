<<<TAR_UNCOMPRESS>>>
        <<<PATCH>>>
        for config_i in $(find -name "config.sub")
        do
                cp -a -f <<<CROSS_TOOLS_PREFIX>>>/share/automake*/config.* $(dirname ${config_i})/
        done
        if [ ! -f configure ]; then
                autoreconf -ifv
        fi
	rm -f ${X86_64_SYSROOT_DIR}/usr/lib${LIB_SUFF}/pkgconfig/cairo.pc
        ./configure ${COMMON_CONFIG} --enable-tee --enable-gl --enable-xlib-xcb --disable-trace --enable-malloc0returnsnull
        CC="${CROSS_TARGET}-gcc" CXX="${CROSS_TARGET}-g++" <<<MAKE>>>
        make DESTDIR=${X86_64_SYSROOT_DIR} install
        rm -f ${X86_64_SYSROOT_DIR}/usr/lib64/*.la
<<<CLEAR_DIR>>>

