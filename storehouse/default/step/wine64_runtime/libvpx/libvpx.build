<<<TAR_UNCOMPRESS>>>
    sed -i 's/cp -p/cp/' build/make/Makefile
    mkdir cross-build
    pushd cross-build
        CC="${CROSS_TARGET}-gcc" CXX="${CROSS_TARGET}-g++" \
        ../configure --prefix=/usr --libdir=/usr/lib${LIB_SUFF} \
                     --target=generic-gnu --enable-shared
	<<<MAKE_AND_INSTALL>>>
    popd
<<<CLEAR_DIR>>>
