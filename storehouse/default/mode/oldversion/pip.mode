	_PYTHON_HOST_PLATFORM=linux-loongarch64 _PYTHON_SYSCONFIGDATA_NAME=_sysconfigdata__linux_${CROSS_TARGET} <<<CROSS_TOOLS_PREFIX>>>/bin/pip3 wheel -w dist --no-build-isolation --no-deps ${PWD}
