# 比较两个版本之间的大小
# 相同返回0，第一个大于第二个返回1，否则返回-1
function strversion_comp
{
        if [ "x${1}" == "x${2}" ]; then
                echo "0"
		return
        fi
MAX_VERSION=$(echo "${1}
${2}" | sort -V -r | head -n 1)
        if [ "x${MAX_VERSION}" == "x${1}" ]; then
                echo "1"
        else
                echo "-1"
        fi
	return
}

#通过指定版本来获取指定文件中相应部分的内容
#参数1: 文本文件名
#参数2: 指定版本
#返回内容: 在文本中使用“[[[版本]]]”定义的内容，当指定版本大于或者等于时获取并返回。
function get_body_with_version_new
{

if [ "x${1}" == "x" ]; then
        echo ""
        return
fi
input_file="${1}"
target=$(echo ${2} | sed "s@-default\$@@g")

awk -v target="$target" '
    # 语义化版本比较函数（仅比较数字部分）
    function ver_compare(a, b,    a_parts, b_parts, n, i, a_num, b_num) {
        split(a, a_parts, /[^0-9]+/)
        split(b, b_parts, /[^0-9]+/)
        n = length(a_parts) > length(b_parts) ? length(a_parts) : length(b_parts)
        for (i=1; i<=n; i++) {
            a_num = (i in a_parts) ? a_parts[i] + 0 : 0
            b_num = (i in b_parts) ? b_parts[i] + 0 : 0
            if (a_num < b_num) return -1
            if (a_num > b_num) return 1
        }
        return 0
    }

    BEGIN {
        first_unmarked = ""    # 首个无标记段落
        best_ver = ""          # 符合条件的最小版本号
        best_content = ""      # 目标版本内容
        current_ver = ""       # 当前处理的版本号
        has_versions = 0       # 是否遇到版本标记
    }

    # 匹配版本标记行 [[[x.x.x]]]
    /^\[\[\[[0-9a-zA-Z.-]+\]\]\]$/ {
        has_versions = 1
        # 精确提取版本号
        if (match($0, /^\[\[\[(.+)\]\]\]$/, arr)) {
            ver = arr[1]
        } else {
            ver = ""
            next
        }

        # 仅处理大于等于目标版本的标记
        if (ver_compare(ver, target) >= 0) {
            # 选择符合条件的最小版本
            if (best_ver == "" || ver_compare(ver, best_ver) < 0) {
                best_ver = ver
                best_content = ""
            }
            current_ver = ver
        } else {
            current_ver = ""
        }
        next  # 跳过标记行
    }

    # 内容收集逻辑
    {
        if ($0 ~ /^#[[:blank:]]/) {
            next
        }

        if (has_versions) {
            if (current_ver == "" ) {
                next
            } else {
                if (current_ver == best_ver) {
                    best_content = best_content $0 "\n"
                }
            }
        } else {
            first_unmarked = first_unmarked $0 "\n"
        }
    }

    END {
        if (best_content != "") {
            printf "%s", best_content
        } else {
            printf "%s", first_unmarked
        }
    }
' "$input_file"
}

function get_body_with_version
{
	declare LINE_START=1
	declare LINE_STOP=1
	declare IF_LINE=""
	declare VERSION=""

	if [ "x${1}" == "x" ]; then
        	echo ""
	        return
	fi

	declare FORMAT_VERSION=$(echo ${2} | sed "s@-default\$@@g")

	declare LINES=$(grep -n "^\[\[\[" ${1})
	if [ "x${LINES}" == "x" ] || [ "x${FORMAT_VERSION}" == "x" ]; then
        	cat ${1} | grep -v "^#[[:blank:]]"
	        return
	fi

	for i in $LINES
	do
        	declare -i LINE_STOP=$(echo "$i" | gawk -F':' '{ print $1 }')-1
	        VERSION=$(echo "$i" | gawk -F':' '{ print $2 }')
        	IF_LINE=$(echo "${VERSION}" | sed "s@^\[\[\[\(.*\)\]\]\]\$@\1@g")
	        if [ "$(strversion_comp "${FORMAT_VERSION}" "${IF_LINE}")" == "1" ]; then
        	        break;
	        else
        	        declare -i LINE_START=$(echo "$i" | gawk -F':' '{ print $1 }')+1
                	LINE_STOP=${LINE_START}
	                continue;
        	fi
	done

	if [ "x${LINE_START}" == "x${LINE_STOP}" ]; then
        	sed -n "${LINE_START},\$p" ${1} | grep -v "^#[[:blank:]]"
	else
        	sed -n "${LINE_START},${LINE_STOP}p" ${1} | grep -v "^#[[:blank:]]"
	fi
}

