	declare RET_STR="NULL"
        TARGET_ARCH=${2}
        STEP_BUILDNAME=$(echo ${1} | awk -F'/' '{ print $2 }')
        STEP_PACKAGENAME=$(echo ${1} | awk -F'/' '{ print $3 }')
	if [ -f storehouse/${ZZ_NAME}/env/${STEP_BUILDNAME}/lock ]; then
		LOCK_GROUP=$(cat storehouse/${ZZ_NAME}/env/${STEP_BUILDNAME}/lock | grep "^lock=" | head -n1 | gawk -F'=' '{ print $2 }')
		if [ "x${LOCK_GROUP}" == "x1" ]; then
			echo "GROUP"
			return
		fi
	fi
#        STEPNAME=storehouse/${ZZ_NAME}/${1}/${STEP_PACKAGENAME}
	STEPNAME=$(get_arch_file storehouse/${ZZ_NAME}/step/${STEP_BUILDNAME} ${STEP_PACKAGENAME}/${STEP_PACKAGENAME} ${TARGET_ARCH})
        if [ -f ${STEPNAME} ]; then
                PACKAGE=$(cat ${STEPNAME} | grep "^PACKAGE=" | head -n1 | gawk -F'=' '{ print $2 }')
                LOCK_VERSION=$(cat ${STEPNAME} | grep "^LOCK_MODE=" | head -n1 | gawk -F'=' '{ print $2 }')
		if [ "x${LOCK_VERSION}" == "xAUTO" ]; then
			RET_STR="AUTO"
		else
			RET_STR="NULL"
		fi
        else
                RET_STR="NULL"
        fi
	echo "${RET_STR}"
        return
}


