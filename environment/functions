function get_resources
{
	declare RESOURCES_FILE=""
	declare TARGET_ARCH="${3}"
	declare RESOURCES_BODY=$(cat_arch_file ${1} ${2#${1}*} ${3} | grep -v "^#[[:blank:]]")
	if [ "x${RESOURCES_BODY}" != "x" ]; then
		echo "${RESOURCES_BODY}" | while read line
		do
			RESOURCES_FILE=$(echo ${line} | awk -F' ' '{print $1}')
			if [ "x${RESOURCES_FILE}" == "x" ]; then
				continue;
			else
				echo "${RESOURCES_FILE}" | sed "s@<<<TARGET_ARCH>>>@${TARGET_ARCH}@g"
			fi
		done
		echo " "
	else
		echo -n ""
	fi
	echo ""
}



