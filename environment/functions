# 对字符串的内容按照指定的字段进行替换后输出
# 参数1：替换前的字符串内容
# 参数2：替换字段设置
# 输出：替换后的字符串
function replace_package_info
{
	if [ "x${1}" == "x" ]; then
		echo ""
		return;
	fi
	if [ "x${2}" == "x" ]; then
		echo "${1}"
		return;
	fi

	REPO_INFO_NAME=$(echo "${1}" | grep -o "@.*@" | sed 's,@,,g')
	if [ "x${REPO_INFO_NAME}" == "x" ]; then
		echo "${1}"
		return
	fi

	if [ ! -f git_repo_info/${REPO_INFO_NAME} ]; then
		echo ""
		return
	fi

	GIT_REPO_INFO_FIELD=$(cat git_repo_info/${REPO_INFO_NAME} | grep "^${2}=" | head -n1 | gawk -F'=' '{ print $2 }')

	echo "${1}" | sed "s,@${REPO_INFO_NAME}@,${GIT_REPO_INFO_FIELD},g"
	return;
}


