		if [ "x${4}" == "x" ]; then
			LOCK_VERSION=$(cat ${STEPNAME} | grep "^LOCK_VERSION=" | head -n1 | gawk -F'=' '{ print $2 }')
		else
			LOCK_VERSION=${4}
		fi

                if [ "x$PACKAGE" != "xNULL" ]; then
			if [ "x${LOCK_VERSION}" != "x" ]; then
				PACKAGE_VERSION=${LOCK_VERSION}
			else
				PACKAGE_VERSION=$(cat_arch_file package_version/$(get_version_name) ${PACKAGE}.version ${TARGET_ARCH})
			fi
			PACKAGE_DIR=$(get_arch_directory sources/${PACKAGE} ${PACKAGE_VERSION} ${TARGET_ARCH})
			echo "${1}: package_dir ${PACKAGE_DIR}" >> /tmp/info.log
#                        if [ -d sources/${PACKAGE} ]; then
                        if [ -d ${PACKAGE_DIR} ]; then
				SRC_PATH=$(get_arch_directory sources/${PACKAGE} ${PACKAGE_VERSION}/files ${TARGET_ARCH})
				echo "${1}: src_path ${SRC_PATH}" >> /tmp/info.log
				if [ "x${SRC_PATH}" != "xNULL" ] && [ "x${DES_PATH}" != "x" ]; then
					mkdir -p ${DES_PATH}/${STEP_PACKAGENAME}/${PACKAGE_VERSION}/
					RESOURCES=$(get_resources $(dirname ${STEP_PATH}) ${STEPNAME}.resources "${TARGET_ARCH}")
# 					echo "x${RESOURCES} get_resouces $(dirname ${STEP_PATH}) ${STEPNAME}.resources \"${TARGET_ARCH}\""
# 					if [ -f ${STEPNAME}.resources ]; then
					if [ "x${RESOURCES}" != "x" ]; then
						if [ ! -d ${DES_PATH}/${STEP_PACKAGENAME}/${PACKAGE_VERSION} ]; then
							mkdir -p ${DES_PATH}/${STEP_PACKAGENAME}/${PACKAGE_VERSION}
						else
							find ${DES_PATH}/${STEP_PACKAGENAME}/${PACKAGE_VERSION}/ -maxdepth 1 -type f -exec rm '{}' ';'
						fi
# 						RESOURCES=$(get_patches $(dirname ${STEP_PATH}) ${STEPNAME}.resources "${TARGET_ARCH}")
						for resource_file in ${RESOURCES}
						do
							if [ "x${resource_file}" == "xNULL" ]; then
								continue;
							fi
							if [ -f ${SRC_PATH}/${resource_file} ]; then
# 								cp -a ${SRC_PATH}/* ${DES_PATH}/${STEP_PACKAGENAME}/${PACKAGE_VERSION}/
								cp -a ${SRC_PATH}/${resource_file} ${DES_PATH}/${STEP_PACKAGENAME}/${PACKAGE_VERSION}/
							else
								echo "缺少 ${SRC_PATH}/${resource_file} 资源文件。"
							fi
						done
					else
						cp -a ${SRC_PATH}/* ${DES_PATH}/${STEP_PACKAGENAME}/${PACKAGE_VERSION}/
					fi
#					sed -i "s@<<<PACKAGE_VERSION>>>@${PACKAGE_VERSION}@g" ${DES_PATH}/${STEP_PACKAGENAME}/${PACKAGE_VERSION}/*.url
					if [ "x$?" != "x0" ]; then
						echo "${1}： 在从 ${SRC_PATH} 路径复制文件时出错！" >> /tmp/error.log
						retrun
					fi
					if [ -d ${DES_PATH}/${STEP_PACKAGENAME}/${PACKAGE_VERSION}/patches ]; then
						rm -f ${DES_PATH}/${STEP_PACKAGENAME}/${PACKAGE_VERSION}/patches/*.{patch*,diff*}
					fi
					PATCHES=$(get_patches $(dirname ${STEP_PATH}) ${STEPNAME}.patches "${TARGET_ARCH}")
# 					if [ -f ${STEPNAME}.patches ]; then
					if [ "x${PATCHES}" != "x" ]; then
						if [ ! -d ${DES_PATH}/${STEP_PACKAGENAME}/${PACKAGE_VERSION}/patches ]; then
							mkdir -p ${DES_PATH}/${STEP_PACKAGENAME}/${PACKAGE_VERSION}/patches
						fi
# 						PATCHES=$(get_patches $(dirname ${STEP_PATH}) ${STEPNAME}.patches "${TARGET_ARCH}")
						for patch_file in ${PATCHES}
						do
							if [ -f ${SRC_PATH}/patches/${patch_file} ]; then
#								echo "复制 ${SRC_PATH}/patches/${patch_file} 到 ${DES_PATH}/${STEP_PACKAGENAME}/${PACKAGE_VERSION}/patches/"
								cp -a ${SRC_PATH}/patches/${patch_file} ${DES_PATH}/${STEP_PACKAGENAME}/${PACKAGE_VERSION}/patches/
							else
								echo "缺少 ${SRC_PATH}/patches/${patch_file} 补丁文件。"
							fi
						done
					fi
				else
					if [ -f ${STEPNAME}.patches ]; then
						PATCHES=$(get_patches $(dirname ${STEP_PATH}) ${STEPNAME}.patches "${TARGET_ARCH}")
                                                for patch_file in ${PATCHES}
						do
							echo "${STEP_PACKAGENAME} ${PACKAGE_VERSION} 版本缺少 ${patch_file} 补丁文件。"
						done
					fi
				fi
                        else
                                echo "${1}： 没有发现 ${PACKAGE_VERSION} 的版本相关文件目录 ${PACKAGE_DIR} 。" >> /tmp/error.log
                                return
                        fi

                else
                                echo "${1}： 没有发现对应的软件包名。" >> /tmp/error.log
				return
                fi
        else
                echo "${1}：该步骤文件不存在。" >> /tmp/error.log
                return
        fi
}

function form_stepname_to_version
{
        declare PACKAGE=""
        declare PACKAGE_VERSION=""
        declare LOCK_VERSION=""
        declare STEP_BUILDNAME=""
        declare STEP_PACKAGENAME=""
        declare STEPNAME=""
        declare ORIG_NAME=""
        declare TARGET_ARCH=""
	declare RET_STR="NULL"
        TARGET_ARCH=${2}
        STEP_BUILDNAME=$(echo ${1} | awk -F'/' '{ print $2 }')
        STEP_PACKAGENAME=$(echo ${1} | awk -F'/' '{ print $3 }')
#        STEPNAME=storehouse/${ZZ_NAME}/${1}/${STEP_PACKAGENAME}
	STEPNAME=$(get_arch_file storehouse/${ZZ_NAME}/step/${STEP_BUILDNAME} ${STEP_PACKAGENAME}/${STEP_PACKAGENAME} ${TARGET_ARCH})
        if [ -f ${STEPNAME} ]; then
                PACKAGE=$(cat ${STEPNAME} | grep "^PACKAGE=" | head -n1 | gawk -F'=' '{ print $2 }')
                LOCK_VERSION=$(cat ${STEPNAME} | grep "^LOCK_VERSION=" | head -n1 | gawk -F'=' '{ print $2 }')
                if [ "x$PACKAGE" != "xNULL" ] && [ "x${PACKAGE}" != "x" ]; then
			if [ "x${LOCK_VERSION}" != "x" ]; then
                        	PACKAGE_VERSION=${LOCK_VERSION}
			else
                        	PACKAGE_VERSION=$(cat_arch_file package_version/$(get_version_name) ${PACKAGE}.version ${TARGET_ARCH})
			fi
                else
                        PACKAGE_VERSION="NULL"
                fi
		ORIG_NAME="$(cat_arch_file package_version/$(get_version_name) ${PACKAGE}.origname ${TARGET_ARCH})"
		if [ "x${ORIG_NAME}" == "x" ]; then
			ORIG_NAME="${PACKAGE}"
		fi
		if [ "x$(find_arch_file package_version/$(get_version_name) ${PACKAGE}.version ${TARGET_ARCH})" == "x1" ]; then
			RET_STR="${PACKAGE_VERSION}|${PACKAGE}|${ORIG_NAME}|${TARGET_ARCH}"
		else
			RET_STR="${PACKAGE_VERSION}|${PACKAGE}|${ORIG_NAME}|NULL"
		fi
		if [ "x${LOCK_VERSION}" != "x" ]; then
			RET_STR="${PACKAGE_VERSION}|${PACKAGE}|${ORIG_NAME}|LOCK_VERSION"
		fi
        else
                echo "${1} 步骤文件不存在!" >> /tmp/error.log
                RET_STR="NULL"
        fi
	echo "${RET_STR}"
        return
}

function soft_lock_mode
{
        declare PACKAGE=""
        declare PACKAGE_VERSION=""
        declare LOCK_VERSION=""
        declare STEP_BUILDNAME=""
        declare STEP_PACKAGENAME=""
        declare STEPNAME=""
        declare ORIG_NAME=""
