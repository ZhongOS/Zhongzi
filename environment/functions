#通过指定step索引文件，从一组step文件重新整理出一个单一的steps文件。
#参数1：开始的step索引文件。
function get_stepfile_to_steps
{
	declare DIRNAME=""
	declare FORMAT_STEP_OPT=""
	if [ -f $1 ]; then
		echo "获取$1"
		for i in $(cat $1 | grep -v "^#[[:blank:]]" | grep -v "^$")
		do
			STEP_FULLSTR=${i}
			STEP_STR=$(echo ${STEP_FULLSTR} | gawk -F'|' '{ print $1 }')
			STEP_OPT=$(echo ${STEP_FULLSTR} | gawk -F'|' '{ print $2 }')
			STR_TMP=$(echo ${STEP_STR} | gawk -F':' '{ print $1 }')
			ARCH_AND_DIRECTORY_STEP=$(echo ${STEP_STR} | gawk -F':' '{ print $2 }')
			FILE=$(echo $STR_TMP | gawk -F'@' '{ print $1 }')
			DIRECTORY=$(echo $STR_TMP | gawk -F'@' '{ print $2 }')
			if [ "x${DIRECTORY}" == "x" ]; then
				DIRECTORY=
			else
				DIRECTORY=${DIRECTORY}/
			fi
                        if [ "x${ARCH_AND_DIRECTORY_STEP}" == "x" ]; then
                                        DIRECTORY_STEP=default.step
                        else
                                DIRECTORY_STEP=${ARCH_AND_DIRECTORY_STEP##*>}
                                if [ "x${DIRECTORY_STEP}" == "x" ]; then
                                        DIRECTORY_STEP=default.step
                                else
                                        DIRECTORY_STEP=${DIRECTORY_STEP}.step
                                fi
                                ARCH_STEP=${ARCH_AND_DIRECTORY_STEP%%${DIRECTORY_STEP}*}
                                if [ "x${ARCH_STEP}" == "x<ARCH>" ]; then
                                        DIRECTORY_STEP="arch/${DISTRO_ARCH}/${DIRECTORY_STEP}"
                                fi
                        fi
#			if [ "x${DIRECTORY_STEP}" == "x" ]; then
#				DIRECTORY_STEP=default.step
#			else
#				DIRECTORY_STEP=${DIRECTORY_STEP}.step
#			fi
			if [ "x${FILE}" == "x" ]; then
				FORMAT_STEP_OPT=$(format_opt_str "${3}" "${STEP_OPT}" "g" "${DIRECTORY%%/}")
				echo "${DIRECTORY}(${DIRECTORY_STEP})"
				get_stepfile_to_steps $(dirname $1)/${DIRECTORY}${DIRECTORY_STEP} $2 "${FORMAT_STEP_OPT}"
			else
#				if [ "x${STEP_OPT}" == "xopt" ] || [ "x${STEP_OPT}" == "xbad" ] ; then
#					STEP_OPT="${3}+f${STEP_OPT}"
#				else
#					STEP_OPT="${3}"
#				fi
#				echo "%"$(dirname $1)/${DIRECTORY}${FILE}
				if [ "x${DIRECTORY:0:1}" == "x/" ]; then
					DIRNAME="step"
					DIRECTORY="${DIRECTORY:1}"
				else
					DIRNAME=$(dirname $1)
				fi
				DIRNAME=$(echo ${DIRNAME} | sed "s@\/arch\/${DISTRO_ARCH}@@g")
				FORMAT_STEP_OPT=$(format_opt_str "${3}" "${STEP_OPT}" "f" "${DIRNAME##*/}_${FILE}")
				echo "%${DIRNAME#${2}*}/"${DIRECTORY}${FILE}"|"${FORMAT_STEP_OPT}
			fi
		done
	fi
}

